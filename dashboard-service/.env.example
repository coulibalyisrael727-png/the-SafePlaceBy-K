# ─── Dashboard Microservice — Variables d'environnement ───────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Django core
DJANGO_SECRET_KEY=changez-moi-par-une-cle-longue-et-aleatoire
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com

# ─── URL de l'application principale ──────────────────────────────────────────
# L'adresse où tourne votre site SafePlace (port 8000 en local)
MAIN_API_URL=http://127.0.0.1:8000/api/v1/
MAIN_SITE_URL=http://127.0.0.1:8000

# ─── Clé API partagée (doit être IDENTIQUE dans les deux apps) ────────────────
# Dans Safeplace/settings.py: DASHBOARD_API_KEY = "..."
DASHBOARD_API_KEY=safeplace_secret_dashboard_key_2026
