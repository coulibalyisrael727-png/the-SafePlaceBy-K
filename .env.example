# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,safeplace.com,www.safeplace.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=safeplace_db
DB_USER=safeplace_user
DB_PASSWORD=your_secure_database_password_123
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_123

# Stripe Payment Gateway
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@safeplace.com

# SSL/TLS (for production)
USE_HTTPS=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# Site Configuration
SITE_NAME=The SafePlace by K
SITE_URL=https://safeplace.com
ADMIN_EMAIL=admin@safeplace.com
