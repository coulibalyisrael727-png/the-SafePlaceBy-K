# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,safeplace.com,www.safeplace.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=safeplace_db
DB_USER=safeplace_user
DB_PASSWORD=your_secure_database_password_123
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_123

# Stripe (optionnel — dons par carte uniquement si STRIPE_DONATIONS_ENABLED=true)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_DONATIONS_ENABLED=false

# Dons sans frais d’intégration : liens + virement (remplir au moins un lien ou l’IBAN)
DONATION_PAYPAL_URL=https://paypal.me/votrecompte
DONATION_KOFI_URL=
DONATION_TIPEEE_URL=
DONATION_UTIP_URL=
DONATION_BUYMEACOFFEE_URL=
DONATION_BANK_IBAN=FR00 0000 0000 0000 0000 0000 000
DONATION_BANK_LABEL=The SafePlace by K
DONATION_NOTIFY_EMAIL=admin@safeplace.com

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@safeplace.com

# SSL/TLS (for production)
USE_HTTPS=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# Site Configuration
SITE_NAME=The SafePlace by K
SITE_URL=https://safeplace.com
ADMIN_EMAIL=admin@safeplace.com
